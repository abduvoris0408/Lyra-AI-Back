# ===== Lyra API — muhit o'zgaruvchilari =====
# Ushbu faylni `.env` deb nusxalang va qiymatlarni to'ldiring.

# Server porti (web 3000 da, shuning uchun API 3001 da)
PORT=3001

# Frontend manzili (CORS uchun). Vergul bilan bir nechta bo'lishi mumkin.
WEB_ORIGIN=http://localhost:3000

# ===== Gemini — Google AI Studio (BEPUL, billingsiz) =====
# Kalitni shu yerdan oling:  https://aistudio.google.com/apikey
# "Create API key" → kalit "AIza..." bilan boshlanadi. Karta/billing SHART EMAS.
GEMINI_API_KEY=

# Ixtiyoriy: bazaviy URL (odatda o'zgartirilmaydi)
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta

# Standart model (frontend yubormasa shu ishlatiladi)
GEMINI_DEFAULT_MODEL=gemini-flash-latest
# Asosiy model band (503) yoki kvotasi tugaganda (429) avtomatik o'tiladigan model
GEMINI_FALLBACK_MODEL=gemini-flash-lite-latest

# ===== Ma'lumotlar bazasi (Postgres — Neon/Supabase) =====
# Neon: https://neon.tech  ·  Supabase: https://supabase.com
DATABASE_URL=postgresql://user:password@host:5432/lyra?sslmode=require

# ===== JWT sessiya sirlari (uzun, tasodifiy satrlar) =====
# Yaratish:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# ===== Google OAuth (server tomonda tekshiriladi) =====
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Prod'da cross-subdomain cookie uchun (masalan ".lyra.app"). Dev'da bo'sh qoldiring.
COOKIE_DOMAIN=
